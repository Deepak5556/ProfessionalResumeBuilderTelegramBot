# ── Telegram ──────────────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_from_botfather

# ── AI Provider: choose ONE (gemini | groq | grok) ────────
AI_PROVIDER=gemini

# Gemini (Google AI Studio — free): https://aistudio.google.com/app/apikey
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=

# Groq (Llama 3.3 70B — free): https://console.groq.com/keys
GROQ_API_KEY_1=
GROQ_API_KEY_2=

# Grok (xAI — free tier): https://console.x.ai/
GROK_API_KEY=xai-...


DEEPSEEK_API_KEY=
MISTRAL_API_KEY=

OPEN_ROUTER_API_KEY=

# ── Database ───────────────────────────────────────────────
DB_PATH=./data/resumebot.db

# ── File storage ───────────────────────────────────────────
TEMP_DIR=/tmp/resumebot

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ── Rate limiting ──────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=2000
MAX_CONCURRENT_PIPELINES=10
